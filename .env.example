# ============================================================
# SARANA & PRASARANA — KONFIGURASI ENVIRONMENT
# ============================================================
# Salin file ini ke .env dan isi dengan nilai yang sesuai
# cp .env.example .env
# ============================================================

# --- DATABASE ---
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=annadzir_booking

# --- EMAIL (Brevo SMTP) ---
# Dapatkan SMTP Key di: app.brevo.com → Settings → SMTP & API
# Login SMTP (bukan email biasa, lihat di halaman SMTP Brevo)
MAIL_USERNAME=your_smtp_login@smtp-brevo.com
MAIL_PASSWORD=your_brevo_smtp_key
# Email pengirim (harus diverifikasi sebagai Sender di Brevo)
MAIL_FROM=noreply@yourdomain.com
